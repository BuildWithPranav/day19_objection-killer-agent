# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000
DATABASE_PATH=./data/objection_killer.db
LOG_LEVEL=INFO

# Auth for sales reps/dashboard/API. Change before deploy.
REP_SHARED_TOKEN=change-me-long-random-token

# Realtime speech-to-text.
# deepgram is implemented. mock is useful for tests/local dashboard without API calls.
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# Optional LLM fallback for summarizing low-confidence objections.
# Keep disabled for sub-1.5s path; enable only for non-critical enrichment.
LLM_ENABLED=false
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# Latency controls
OBJECTION_DEBOUNCE_SECONDS=8
MIN_OBJECTION_CONFIDENCE=0.62
MAX_CARDS_PER_OBJECTION=3
